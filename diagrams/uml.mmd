classDiagram
    class Owner {
        +string name
        +list~Pet~ pets
        +int time_available
        +dict preferences
        +add_pet(pet)
    }
    class Pet {
        +string name
        +string species
        +string breed?
        +list~Task~ tasks
        +add_task(task)
    }
    class Task {
        +string description
        +string task_type
        +int priority
        +int duration_min
        +bool completed
        +mark_complete()
    }
    class Scheduler {
        +generate_plan(pet, time_budget) list~dict~
        +generate_all_plans(owner) dict
    }
    Owner "1" --> "*" Pet : has
    Pet "1" --> "*" Task : has
    Scheduler ..> Owner : splits time_available across pets
    Scheduler ..> Pet : builds one plan per pet
